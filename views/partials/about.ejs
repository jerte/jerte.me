<div id="about" class="content alignCenter"> 
	<h1>about</h1>
	<hr width="40%">
	<table class="width100 fixedLayout">
		<tr><td><h2>education</h2><hr width="35%"></td></tr>
			<tr><td class="project">
				<p class="margin0">The University of North Carolina at Chapel Hill</p>
				<p class="margin0">B.S. Computer Science</p>
				<p class="margin0">Neuroscience Minor</p></td></tr>
			<tr><td>
				<p class="bold">Coursework</p>
				<table class="fixedLayout width100">
				<% for(var i=0; i<courses.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td class="project underlineHover"><%= courses[i] %>,</td></tr>
					<% } else { %>
						<td class="project underlineHover"><%= courses[i] %>,</td>
					<% } %>
				<% }; %>
				<td class="project underlineHover"><%= courses[courses.length-1] %></td></tr>
				</table>

		</td></tr>
	</table>
	<hr width="30%">
	<hr width="25%">
	<table class="width100 fixedLayout">
		<tr><td>
			<h2>skills</h2><hr width="35%">
		</td></tr>
			
		<tr><td class="project">
			<p><span class="bold">Languages: </span>
				<% for(var i=0; i<languages.length-1; i++) { %>
					<%= languages[i] %>,
				<% } %>
				<%= languages[languages.length-1] %>
			</p>
		</td></tr>

		<tr><td class="project"><p><span class="bold">Operating Systems: </span>
			<% for(var i=0; i<os_s.length-1; i++) { %>
				<%= os_s[i] %>,
			<% } %>
			<%= os_s[os_s.length-1] %>

			</p></td></tr>
		<tr><td class="project"><p class="bold">Soft Skills</p>
			<table class="fixedLayout width100">
			<% for(var i=0; i<soft_skills.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td><%= soft_skills[i] %>,</td></tr>
					<% } else { %>
						<td><%= soft_skills[i] %>,</td>
					<% } %>
				<% }; %>
				<td><%= soft_skills[soft_skills.length-1] %>
				</table>	
		
		</p></td></tr>
		</table>
		<hr width="30%">
		<hr width="25%">
		<table>
		
		<tr><td><h2>interests</h2><hr width="35%">
			<table class="fixedLayout width100">
			<% for(var i=0; i<interests.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td class="underlineHover project"><%= interests[i] %>,</td></tr>
					<% } else { %>
						<td class="underlineHover project"><%= interests[i] %>,</td>
					<% } %>
				<% }; %>
				<td class="underlineHover project"><%= interests[interests.length-1] %></td></tr>
				</table></td></tr>

	</table>
	<hr width="30%">
	<hr width="25%">
</div>
