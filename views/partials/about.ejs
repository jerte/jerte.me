<div id="about" class="content alignCenter"> 
	<h1>about</h1>
	<hr width="40%">
	<table class="blackBorder width100 fixedLayout">
		<tr><td><h2>education</h2></td></tr>
			<tr><td class="blackBorder">
				<p>The University of North Carolina at Chapel Hill</p>
				<p>B.S. Computer Science</p>
				<p>Neuroscience Minor</p></td></tr>
			<tr><td class="blackBorder">
				<p>Coursework</p>
				<table class="fixedLayout width100">
				<% for(var i=0; i<courses.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td><%= courses[i] %>,</td></tr>
					<% } else { %>
						<td><%= courses[i] %>,</td>
					<% } %>
				<% }; %>
				<td><%= courses[courses.length-1] %></td></tr>
				</table>	
		
		<tr><td><h2>skills</h2></td></tr>
		<tr><td class="blackBorder"><p>Languages:
			<% for(var i=0; i<languages.length-1; i++) { %>
				<%= languages[i] %>,
			<% } %>
			<%= languages[languages.length-1] %>
			</p></td></tr>

		<tr><td class="blackBorder"><p>Operating Systems:
			<% for(var i=0; i<os_s.length-1; i++) { %>
				<%= os_s[i] %>,
			<% } %>
			<%= os_s[os_s.length-1] %>

			</p></td></tr>
		<tr><td class="blackBorder"><p>Soft Skills</p>
			<table class="fixedLayout width100">
			<% for(var i=0; i<soft_skills.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td><%= soft_skills[i] %>,</td></tr>
					<% } else { %>
						<td><%= soft_skills[i] %>,</td>
					<% } %>
				<% }; %>
				<td><%= soft_skills[soft_skills.length-1] %>
				</table>	
		
		</p></td></tr>

		<tr><td><h2>interests</h2>
			<table class="fixedLayout width100">
			<% for(var i=0; i<interests.length-1; i++) { %>
					<% if (i==0 || i%3==0) { %>
						<tr>
					<% } %>
					<% if ((i+1)%3==0) { %>
						<td><%= interests[i] %>,</td></tr>
					<% } else { %>
						<td><%= interests[i] %>,</td>
					<% } %>
				<% }; %>
				<td><%= interests[interests.length-1] %>
				</table></td></tr>

	</table>
</div>
